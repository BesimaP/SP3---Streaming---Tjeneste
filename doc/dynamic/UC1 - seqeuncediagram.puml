@startuml
!pragma layout smetana

actor Bruger

participant Main
participant StreamingService
participant Menu
participant UserController
participant FileIO
participant TextUI

Main -> StreamingService : new StreamingService()
StreamingService -> Menu : new Menu(...)
StreamingService -> UserController : new UserController(...)

Main -> StreamingService : startSystem()
StreamingService -> TextUI : displayMsg("Welcome to BLLKstream")

StreamingService -> FileIO : readData("data/movies.csv")
FileIO --> StreamingService : ArrayList<String>
note right of StreamingService : Opretter Movie-objekter\nog tilføjer kategorier

StreamingService -> FileIO : readData("data/series.csv")
FileIO --> StreamingService : ArrayList<String>
note right of StreamingService : Opretter Series, Season\nog Episode-objekter

StreamingService -> FileIO : readData("data/users.csv")
FileIO --> StreamingService : ArrayList<String>

alt OBS: filen kan ikke læses
    FileIO --> StreamingService : tom liste
    StreamingService -> TextUI : displayMsg("Filen kunne ikke læses")
end

note right of StreamingService : Opretter User-objekter

alt ingen brugere findes
    StreamingService -> UserController : registerUser()
else brugere findes
    StreamingService -> Menu : showStartMenu()
    Menu -> TextUI : displayMsg("1. Login\n2. Opret bruger")
    TextUI --> Bruger : viser startmenu
end

@enduml