@startuml

actor Bruger

participant UserController
participant StreamingService
participant TextUI
participant FileIO

Bruger -> UserController : registerUser()

loop maks 3 forsøg
    UserController -> TextUI : promptText("Enter your username")
    TextUI --> Bruger : viser prompt
    Bruger -> TextUI : indtaster brugernavn
    TextUI --> UserController : username

    alt OBS: brugernavnet findes allerede
        UserController -> TextUI : displayMsg("Username already exists")
        TextUI --> Bruger : viser fejlbesked
    else brugernavnet er ledigt
        UserController -> TextUI : promptText("Enter your password")
        TextUI --> Bruger : viser prompt
        Bruger -> TextUI : indtaster adgangskode
        TextUI --> UserController : password

        UserController -> StreamingService : addUser(newUser)
        UserController -> StreamingService : saveUsers()
        StreamingService -> FileIO : saveData("data/users.csv")

        UserController -> TextUI : displayMsg("User created!")
        UserController -> UserController : loginUser()
        return
    end
end

UserController -> TextUI : displayMsg("Too many attempts")
UserController -> UserController : showStartMenu()

@enduml