@startuml
!pragma layout smetana
actor User
participant StreamingService
participant TextUI
participant FileIO

User -> StreamingService : registerUser()

loop maks 3 forsøg
    StreamingService -> TextUI : promptText("Enter your username")
    TextUI --> User : viser prompt
    User -> TextUI : indtaster brugernavn
    TextUI --> StreamingService : username

    alt brugernavnet er taget
        StreamingService -> TextUI : displayMsg("Username already exists")
        TextUI --> User : viser fejlbesked
    else brugernavnet er ledigt
        StreamingService -> TextUI : promptText("Enter your password")
        TextUI --> User : viser prompt
        User -> TextUI : indtaster adgangskode
        TextUI --> StreamingService : password

        StreamingService -> FileIO : saveUsers()
        FileIO --> StreamingService : gemt

        StreamingService -> StreamingService : loginUser()
    end
end

StreamingService -> TextUI : displayMsg("Too many attempts")
StreamingService -> StreamingService : showStartMenu()

@enduml