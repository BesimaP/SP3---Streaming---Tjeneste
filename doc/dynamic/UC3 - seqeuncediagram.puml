@startuml

actor Bruger

participant UserController
participant StreamingService
participant Menu
participant TextUI

Bruger -> UserController : loginUser()

loop maks 3 forsøg
    UserController -> TextUI : promptText("Enter your username")
    TextUI --> Bruger : viser prompt
    Bruger -> TextUI : indtaster brugernavn
    TextUI --> UserController : username

    UserController -> TextUI : promptText("Enter your password")
    TextUI --> Bruger : viser prompt
    Bruger -> TextUI : indtaster adgangskode
    TextUI --> UserController : password

    UserController -> StreamingService : getUserList()
    StreamingService --> UserController : ArrayList<User>

    alt login lykkedes
        UserController -> TextUI : displayMsg("Login successful")
        UserController -> Menu : run(user)
    else OBS: forkert brugernavn eller password
        UserController -> TextUI : displayMsg("Wrong username or password")
        TextUI --> Bruger : viser fejlbesked og antal forsøg tilbage
    end
end

UserController -> TextUI : displayMsg("Too many attempts")
UserController -> Menu : showStartMenu()

@enduml